# ---- Application ----
APP_NAME=Instabot
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
PORT=8080

# ---- Meta / Instagram ----
# Random string you choose — used during webhook verification
VERIFY_TOKEN=your_webhook_verify_token_here

# Long-lived Page access token with instagram_manage_comments permission
META_ACCESS_TOKEN=your_meta_access_token_here
META_API_VERSION=v21.0
INSTAGRAM_ACCOUNT_ID=
# graph.instagram.com for Instagram Business Login (IGAA tokens)
# graph.facebook.com for Facebook Page-linked tokens
META_GRAPH_HOST=graph.instagram.com
# Optional — needed to exchange short-lived tokens for 60-day tokens
META_APP_SECRET=

# ---- Google Gemini ----
GEMINI_API_KEY=your_gemini_api_key_here
# gemini-2.0-flash has 0 free-tier quota on most projects — use 2.5+ instead
GEMINI_MODEL=gemini-2.5-flash

# ---- Database ----
# Local PostgreSQL example:
DATABASE_URL=postgresql://instabot:instabot@localhost:5432/instabot

# ---- Reply Behavior ----
REPLY_DELAY_MIN_SECONDS=10
REPLY_DELAY_MAX_SECONDS=90

# ---- HTTP Client ----
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
