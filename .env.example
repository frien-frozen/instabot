# ---- Application ----
APP_NAME=Instabot
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
PORT=8080

# ---- Meta / Instagram ----
# Random string you choose — used during webhook verification
VERIFY_TOKEN=your_webhook_verify_token_here

# Long-lived Page access token with instagram_manage_comments permission
META_ACCESS_TOKEN=your_meta_access_token_here
META_API_VERSION=v21.0
INSTAGRAM_ACCOUNT_ID=17841451815192333
INSTAGRAM_USER_ID=17841451815192333
# graph.instagram.com for Instagram Business Login (IGAA tokens)
# graph.facebook.com for Facebook Page-linked tokens
META_GRAPH_HOST=graph.instagram.com
# Optional — needed to exchange short-lived tokens for 60-day tokens
META_APP_SECRET=

# ---- Google Gemini ----
GEMINI_API_KEY=your_gemini_api_key_here
# gemini-2.0-flash has 0 free-tier quota on most projects — use 2.5+ instead
# Recommended: gemini-2.5-flash-lite (paid flash). Do NOT use gemma-* models here.
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional comma-separated fallback chain when the primary model is unavailable
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# ---- Database ----
# Local PostgreSQL example:
DATABASE_URL=postgresql://instabot:instabot@localhost:5432/instabot

# ---- Reply Behavior ----
# Comment reply delay (seconds) — random between min and max before posting
REPLY_DELAY_MIN_SECONDS=3
REPLY_DELAY_MAX_SECONDS=15

# ---- Feature toggles ----
COMMENTS_ENABLED=true
MESSAGES_ENABLED=true
MENTIONS_ENABLED=true
STORY_MENTIONS_ENABLED=true
# Number of prior DM turns sent to Gemini for context
DM_HISTORY_LIMIT=20
# Fetch Instagram profile (name, username, follow status) for warmer replies
PROFILE_CONTEXT_ENABLED=true

# ---- AI prompt (optional override) ----
# Leave empty to use the default prompt from settings table / built-in default
SYSTEM_PROMPT=

# ---- Worker ----
WORKER_BATCH_SIZE=20

# ---- Telegram Admin ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=123456789

# ---- HTTP Client ----
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
